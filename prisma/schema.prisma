generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // NOTE: Bị bypass url ở PrismaService, nhưng Prisma vẫn cần 1 placeholder để CLI ko bị lỗi
  url      = "postgresql://postgres:postgres@localhost:5432/forgeai_auth?schema=public"
}

enum Gender {
  male
  female
}

enum ExerciseDifficulty {
  beginner
  intermediate
  advanced
}

enum WorkoutGoal {
  strength
  muscle_gain
  fat_loss
  mobility
  general_fitness
}

enum WorkoutStatus {
  draft
  planned
  completed
  archived
}

enum WorkoutEffortFeedback {
  too_easy
  just_right
  too_hard
}

enum Visibility {
  private
  public
  system
}

model User {
  id                 String              @id @default(uuid())
  fullName           String
  email              String              @unique
  passwordHash       String
  gender             Gender
  dateOfBirth        DateTime
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  refreshTokens      RefreshToken[]
  exercises          Exercise[]
  workouts           Workout[]
  bodyMetrics        BodyMetric[]
  passwordResetOtps  PasswordResetOtp[]
  workoutCompletions WorkoutCompletion[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetOtp {
  id              String    @id @default(uuid())
  userId          String
  otpHash         String
  resetTokenHash  String?
  attempts        Int       @default(0)
  expiresAt       DateTime
  consumedAt      DateTime?
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model BodyMetric {
  id          String   @id @default(uuid())
  userId      String
  weightKg    Float?
  heightCm    Float?
  bodyFatPct  Float?
  muscleMass  Float?
  chestCm     Float?
  waistCm     Float?
  hipsCm      Float?
  notes       String?
  recordedAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([recordedAt])
}

model Exercise {
  id           String             @id @default(uuid())
  ownerId      String?
  name         String
  description  String?
  muscleGroups String[]
  equipment    String
  difficulty   ExerciseDifficulty
  instructions String[]
  safetyNotes  String[]
  videoUrl     String?
  imageUrl     String?
  visibility   Visibility         @default(private)
  deletedAt    DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  owner        User?              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  workoutItems WorkoutItem[]

  @@index([ownerId])
  @@index([visibility])
  @@index([deletedAt])
  @@map("WorkoutExercise")
}

model Workout {
  id              String        @id @default(uuid())
  userId          String
  title           String
  description     String?
  isTemplate      Boolean       @default(false)
  scheduledFor    DateTime?
  scheduledDays   String[]
  durationMinutes Int?
  difficulty      ExerciseDifficulty?
  goal            WorkoutGoal?
  status          WorkoutStatus @default(draft)
  notes           String?
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           WorkoutItem[]
  completions     WorkoutCompletion[]

  @@index([userId])
  @@index([status])
  @@index([isTemplate])
  @@index([scheduledFor])
  @@index([deletedAt])
}

model WorkoutCompletion {
  id             String                @id @default(uuid())
  userId         String
  workoutId      String
  effort         WorkoutEffortFeedback
  notes          String?
  sorenessAreas  String[]
  durationSeconds Int?
  aiAdjusted     Boolean               @default(false)
  completedAt    DateTime              @default(now())
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout        Workout               @relation(fields: [workoutId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt])
  @@index([workoutId, completedAt])
}

model WorkoutItem {
  id                   String    @id @default(uuid())
  workoutId            String
  exerciseId           String?
  exerciseNameSnapshot String
  order                Int
  restSeconds          Int?
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  workout              Workout   @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise             Exercise? @relation(fields: [exerciseId], references: [id], onDelete: SetNull)
  sets                 WorkoutSet[]

  @@index([workoutId])
  @@index([exerciseId])
  @@unique([workoutId, order])
}

model WorkoutSet {
  id              String      @id @default(uuid())
  workoutItemId   String
  order           Int
  reps            Int?
  weightKg        Float?
  durationSeconds Int?
  restSeconds     Int?
  isCompleted     Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  workoutItem     WorkoutItem @relation(fields: [workoutItemId], references: [id], onDelete: Cascade)

  @@index([workoutItemId])
  @@unique([workoutItemId, order])
}
